# ── Proxmox ──────────────────────────────────────────────────
PROXMOX_HOST=192.168.1.10          # IP o hostname del tuo nodo Proxmox
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=pwmo            # Nome del token API creato su Proxmox
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false           # true solo se hai un certificato valido
PBS_STORAGE=pbs                    # Nome dello storage PBS su Proxmox

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=pwmo
POSTGRES_PASSWORD=cambia-questa-password
POSTGRES_DB=pwmo

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia-questo-segreto-in-produzione

# ── AWS (solo produzione) ─────────────────────────────────────
AWS_SECRET_NAME=pwmo/production
AWS_REGION=eu-west-1
# In produzione il DATABASE_URL viene iniettato da Secrets Manager:
# DATABASE_URL=postgresql://user:pass@rds-endpoint:5432/pwmo
